# ============================================================
# CELL 5 — Dataset PyTorch avec preprocessing intégré
# ============================================================

# ── Pourquoi ces transformations ? ──────────────────────────
# - Resize(224)          : taille standard EfficientNet/ResNet
# - HorizontalFlip       : OK pour IRM (symétrie gauche/droite)
# - Rotation ±15°        : variation réaliste d'acquisition
# - INTERDIT flip vertical : orientation anatomique importante
# - Normalize ImageNet   : obligatoire pour fine-tuning
# ─────────────────────────────────────────────────────────────

IMAGENET_MEAN = [0.485, 0.456, 0.406]
IMAGENET_STD  = [0.229, 0.224, 0.225]

train_transform = transforms.Compose([
    transforms.Resize((CONFIG["image_size"], CONFIG["image_size"])),
    transforms.RandomHorizontalFlip(p=0.5),
    transforms.RandomRotation(degrees=15),
    transforms.ColorJitter(brightness=0.2, contrast=0.2),
    transforms.ToTensor(),
    transforms.Normalize(mean=IMAGENET_MEAN, std=IMAGENET_STD),
])

test_transform = transforms.Compose([
    transforms.Resize((CONFIG["image_size"], CONFIG["image_size"])),
    transforms.ToTensor(),
    transforms.Normalize(mean=IMAGENET_MEAN, std=IMAGENET_STD),
])


class BrainTumorDataset(Dataset):
    def __init__(self, root: Path, split: str, transform, sample_fraction: float = 1.0):
        self.transform = transform
        self.samples   = []

        for cls in CLASSES:
            cls_dir = root / split / cls
            images  = sorted(cls_dir.glob("*.jpg")) + sorted(cls_dir.glob("*.png"))

            if sample_fraction < 1.0:
                random.seed(SEED)
                n = max(4, int(len(images) * sample_fraction))
                images = random.sample(images, n)

            for img_path in images:
                self.samples.append((img_path, CLASS2IDX[cls]))

        print(f"  [{split}] {len(self.samples)} images "
              f"({sample_fraction*100:.0f}% du total)")

    def __len__(self):
        return len(self.samples)

    def __getitem__(self, idx):
        img_path, label = self.samples[idx]
        img = Image.open(img_path).convert("RGB")
        return self.transform(img), label


print("Chargement des datasets...")
train_ds = BrainTumorDataset(DATA_ROOT, "Training", train_transform, CONFIG["sample_fraction"])
test_ds  = BrainTumorDataset(DATA_ROOT, "Testing",  test_transform,  CONFIG["sample_fraction"])

train_loader = DataLoader(train_ds, batch_size=CONFIG["batch_size"],
                          shuffle=True, num_workers=CONFIG["num_workers"],
                          pin_memory=True)
test_loader  = DataLoader(test_ds,  batch_size=CONFIG["batch_size"],
                          shuffle=False, num_workers=CONFIG["num_workers"],
