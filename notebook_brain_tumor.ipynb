# Charge le meilleur modèle
model.load_state_dict(torch.load(OUTPUT_DIR / "best_model.pth", map_location=DEVICE))
model.eval()

all_preds, all_labels, all_probs = [], [], []

with torch.no_grad():
    for imgs, labels in tqdm(test_loader, desc="Évaluation"):
        imgs   = imgs.to(DEVICE)
        logits = model(imgs)
        probs  = torch.softmax(logits, dim=1).cpu().numpy()
        preds  = logits.argmax(1).cpu().numpy()

        all_preds.extend(preds)
        all_labels.extend(labels.numpy())
        all_probs.extend(probs)

all_preds  = np.array(all_preds)
all_labels = np.array(all_labels)

# ── Classification Report ───────────────────────────────────
report_str = classification_report(all_labels, all_preds,
                                    target_names=CLASSES, digits=3)
print("=" * 55)
print("Classification Report")
