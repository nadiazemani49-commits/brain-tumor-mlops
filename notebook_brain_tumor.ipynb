# CELL 10 — Inférence sur une image quelconque
# ============================================================

def predict_image(img_path: str | Path, model: nn.Module) -> dict:
    """
    Retourne la classe prédite + les probabilités par classe.
    """
    transform = transforms.Compose([
        transforms.Resize((CONFIG["image_size"], CONFIG["image_size"])),
        transforms.ToTensor(),
        transforms.Normalize(mean=IMAGENET_MEAN, std=IMAGENET_STD),
    ])

    img    = Image.open(img_path).convert("RGB")
    tensor = transform(img).unsqueeze(0).to(DEVICE)

    model.eval()
    with torch.no_grad():
        logits = model(tensor)
        probs  = torch.softmax(logits, dim=1).squeeze().cpu().numpy()

    pred_idx   = probs.argmax()
    pred_class = CLASSES[pred_idx]
    confidence = float(probs[pred_idx])

    return {
        "predicted_class" : pred_class,
        "confidence"      : confidence,
        "probabilities"   : {cls: float(p) for cls, p in zip(CLASSES, probs)},
    }


# ── Test sur une image aléatoire ─────────────────────────────
sample_cls  = random.choice(CLASSES)
sample_imgs = list((DATA_ROOT / "Testing" / sample_cls).glob("*.jpg"))
sample_img  = random.choice(sample_imgs)

result = predict_image(sample_img, model)

# Affichage
