    mlflow.log_text(report_str, "classification_report.txt")
    mlflow.log_artifact(str(OUTPUT_DIR / "confusion_matrix.png"))
    mlflow.log_artifact(str(OUTPUT_DIR / "learning_curves.png"))

    f1_macro = f1_score(all_labels, all_preds, average="macro")
    mlflow.log_metric("f1_macro", f1_macro)

    for i, cls in enumerate(CLASSES):
        mask    = all_labels == i
        cls_acc = (all_preds[mask] == i).mean() if mask.sum() > 0 else 0.0
        mlflow.log_metric(f"acc_{cls}", float(cls_acc))
        print(f"  {cls:<15} acc = {cls_acc:.3f}")

print(f"\n✅ F1-macro = {f1_macro:.3f}")
