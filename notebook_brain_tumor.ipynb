axes[0].imshow(Image.open(sample_img))
axes[0].axis("off")
correct = "✅" if result["predicted_class"] == sample_cls else "❌"
axes[0].set_title(f"Réel : {sample_cls}\n"
                  f"Prédit : {result['predicted_class']} {correct} "
                  f"({result['confidence']*100:.1f}%)",
                  fontsize=11)

colors = ["#2563EB" if c == result["predicted_class"] else "#CBD5E1" for c in CLASSES]
axes[1].barh(CLASSES, [result["probabilities"][c] for c in CLASSES], color=colors)
axes[1].set_xlim(0, 1)
axes[1].set_xlabel("Probabilité")
axes[1].set_title("Distribution des probabilités")

plt.tight_layout()
plt.savefig(OUTPUT_DIR / "inference_example.png", dpi=150, bbox_inches="tight")
plt.show()

print("\nRésultat :")
