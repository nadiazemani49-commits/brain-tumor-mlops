def validate_dataset(data_root: Path, sample_ratio: float = 0.05) -> dict:
    """
    Vérifie sur un échantillon (5%) :
      - Images corrompues / tronquées
      - Images trop petites (< 32px)
      - Distribution des classes
    
    ✅ Brain Tumor MRI Dataset est déjà propre :
       - Pas de doublons signalés
       - Classes équilibrées (1400 train / 400 test)
       - Format JPG standard
       → Aucun nettoyage manuel nécessaire.
    """
    report = {}

    for split in ["Training", "Testing"]:
        split_dir = data_root / split
        report[split] = {"class_counts": {}, "corrupt": [], "tiny": []}

        for cls in CLASSES:
            cls_dir = split_dir / cls
            if not cls_dir.exists():
                print(f"⚠️  Dossier manquant : {cls_dir}")
                continue

            images = sorted(cls_dir.glob("*.jpg")) + sorted(cls_dir.glob("*.png"))
            report[split]["class_counts"][cls] = len(images)

            # Échantillon aléatoire reproductible
            random.seed(SEED)
            sample = random.sample(images, max(1, int(len(images) * sample_ratio)))

            for img_path in sample:
                try:
                    with Image.open(img_path) as img:
                        img.verify()
                    with Image.open(img_path) as img:
                        w, h = img.size
                        if w < 32 or h < 32:
                            report[split]["tiny"].append(str(img_path))
                except Exception:
                    report[split]["corrupt"].append(str(img_path))

    return report


